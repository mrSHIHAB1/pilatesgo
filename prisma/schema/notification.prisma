enum NotificationType {
  CHAT_MESSAGE
  FEEDBACK_SUBMITTED
  SYSTEM
  NEW_LIKE
  NEW_MATCH
  POST_LIKED
  COMMENT_LIKED
  POST_COMMENTED
  BADGE_EARNED
  BADGE_DOWNGRADE_WARNING
  BADGE_PROXIMITY
  CLUBHOUSE_INACTIVITY
  SUBSCRIPTION_CHANGE
  PAYMENT_ALERT
  ADMIN_UPDATE
  WEEKLY_UPDATE
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
